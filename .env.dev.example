# Development environment template
APP_ENV=dev
DEBUG=True
SECRET_KEY=replace-with-dev-secret
JWT_SIGNING_KEY=replace-with-dev-jwt-signing-key
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8090,http://127.0.0.1:8090
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8090,http://127.0.0.1:8090
SECURE_SSL_REDIRECT=False

DB_HOST=db-dev
DB_PORT=5432
DB_NAME=notesDB
DB_USER=admin
DB_PASSWORD=replace-with-dev-db-password

POSTGRES_DB=notesDB
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-dev-db-password

PYTHONUNBUFFERED=1
