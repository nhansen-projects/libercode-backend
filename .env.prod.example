# Production environment template
APP_ENV=prod
DEBUG=False
SECRET_KEY=replace-with-strong-random-secret
JWT_SIGNING_KEY=replace-with-long-random-jwt-key
ALLOWED_HOSTS=libercode.augustdev.work
CORS_ALLOWED_ORIGINS=https://libercode.augustdev.work,https://libercode.augustdev.work:8090
CSRF_TRUSTED_ORIGINS=https://libercode.augustdev.work,https://libercode.augustdev.work:8090
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

DB_HOST=db-prod
DB_PORT=5432
DB_NAME=notesDB
DB_USER=admin
DB_PASSWORD=replace-with-strong-db-password

POSTGRES_DB=notesDB
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-strong-db-password

PYTHONUNBUFFERED=1
